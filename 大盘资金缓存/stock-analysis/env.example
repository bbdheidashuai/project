# 大模型配置：复制本文件为 stock-analysis 目录下的 .env，填写后重启 Flask。
# 不要将含真实密钥的 .env 提交到版本库。

# ---------- DeepSeek（官方 OpenAI 兼容，推荐）----------
# 在 https://platform.deepseek.com 创建 API Key 后填写：
# LLM_VENDOR=deepseek
# LLM_API_KEY=sk-你的DeepSeek密钥
# 可不写 LLM_API_BASE / LLM_MODEL（程序默认官方地址与 deepseek-chat）
#
# 若手写完整配置，等价于：
# LLM_PROVIDER=openai_compat
# LLM_API_KEY=sk-你的DeepSeek密钥
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# 深度思考版（按官方文档）：
# LLM_MODEL=deepseek-reasoner

# ---------- 指南针 OAMV 活跃市值（可选）----------
# 若已从指南针软件导出 0AMV 日 K CSV（含 date,open,high,low,close,volume），填写绝对路径优先使用：
# COMPASS_OAMV_CSV=D:/data/0AMV.csv
# 未设置时程序按两市成交额 SMA(10,1)/1e7 推算并缓存到 dataset/oamv/

# ---------- 爬虫代理（东方财富等）----------
# 未设置时使用代码内默认代理；设为空字符串 PROXY_URL= 则仅直连
# PROXY_URL=http://user:pass@host:port

# ---------- 通用 ----------
# openai_compat（默认）| gemini | gemini_openai
# LLM_PROVIDER=openai_compat

LLM_API_KEY=

# 非 DeepSeek 时需写；DeepSeek 官方可省略（与 LLM_VENDOR=deepseek 二选一逻辑见上）
# LLM_API_BASE=https://api.openai.com/v1

# LLM_MODEL=gpt-4o-mini

# ---------- hahajimi 反代 / OpenAI 兼容（sk- 密钥）----------
# LLM_API_BASE 须带 /v1，例如：
#   https://new.hahajimi.top/v1
#   https://api-cn.hahajimi.top:2333/v1
# LLM_MODEL=按服务商文档（若走 DeepSeek 模型则填其模型 id）

# ---------- Google 官方 Gemini ----------
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ---------- Google 官方 OpenAI 兼容层 ----------
# LLM_PROVIDER=gemini_openai
# LLM_API_KEY=你的Google密钥
# LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash
